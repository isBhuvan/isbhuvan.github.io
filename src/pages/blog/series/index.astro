</style>

<script>
  // ── Scroll reveal ──
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.05 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  // ── Filter dropdown ──
  const trigger   = document.getElementById('filter-trigger') as HTMLButtonElement;
  const panel     = document.getElementById('filter-panel')!;
  const countBadge = document.getElementById('filter-active-count')!;
  const summary   = document.getElementById('filter-summary')!;

  trigger.addEventListener('click', () => {
    const open = panel.classList.toggle('open');
    trigger.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', e => {
    if (!document.getElementById('filter-dropdown')!.contains(e.target as Node)) {
      panel.classList.remove('open');
      trigger.setAttribute('aria-expanded', 'false');
    }
  });

  // ── Filter logic ──
  const topicBtns  = document.querySelectorAll<HTMLButtonElement>('#filter-panel button[data-topic]');
  const statusBtns = document.querySelectorAll<HTMLButtonElement>('#filter-panel button[data-status]');
  const cards      = document.querySelectorAll<HTMLElement>('#series-list .series-card');
  const empty      = document.getElementById('filter-empty')!;

  let activeTopic  = 'all';
  let activeStatus = 'all';

  function applyFilters() {
    let visible = 0;
    cards.forEach(card => {
      const topics = (card.dataset.topics ?? '').split(',');
      const status = card.dataset.status ?? '';
      const show = (activeTopic === 'all' || topics.includes(activeTopic))
                && (activeStatus === 'all' || status === activeStatus);
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    });
    empty.classList.toggle('visible', visible === 0);

    // Update badge & summary
    const activeCount = (activeTopic !== 'all' ? 1 : 0) + (activeStatus !== 'all' ? 1 : 0);
    countBadge.textContent = String(activeCount);
    countBadge.classList.toggle('visible', activeCount > 0);

    const parts: string[] = [];
    if (activeTopic !== 'all') parts.push(activeTopic);
    if (activeStatus !== 'all') parts.push(activeStatus === 'active' ? 'In Progress' : 'Complete');
    summary.textContent = parts.length ? `Showing: ${parts.join(' · ')}` : '';
  }

  topicBtns.forEach(btn => btn.addEventListener('click', () => {
    topicBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeTopic = btn.dataset.topic ?? 'all';
    applyFilters();
  }));

  statusBtns.forEach(btn => btn.addEventListener('click', () => {
    statusBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeStatus = btn.dataset.status ?? 'all';
    applyFilters();
  }));
</script>
