---
// src/pages/blog/archive.astro
import BlogLayout from "../../layouts/BlogLayout.astro";
import { getCollection } from "astro:content";
import { flatSlug, fmtDate, calcReadTime } from "../../lib/utils";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

// Group by year
const byYear = sorted.reduce<Record<number, typeof sorted>>((acc, post) => {
  const year = new Date(post.data.date).getFullYear();
  (acc[year] ??= []).push(post);
  return acc;
}, {});
const years = Object.keys(byYear)
  .map(Number)
  .sort((a, b) => b - a);

const allTags = [...new Set(sorted.map((p) => p.data.primaryTag).filter(Boolean))].sort() as string[];

---

<BlogLayout
  title="Archive — isBhuvan / Blog"
  description="Every post, in one place."
  crumbs={[{ label: "Archive", href: "/blog/archive" }]}
>
  <!-- Page header -->
  <div class="page-header">
    <div class="page-eyebrow">Archive</div>
    <h1 class="page-title">Every post,<br />in one place.</h1>
    <p class="page-sub">
      {sorted.length} posts across {allTags.length} topics.
    </p>
  </div>

  <!-- Filter bar -->
  <div class="filter-bar">
    <span class="filter-label">Filter</span>
    <button class="filter-btn active" data-filter="all">All</button>
    {
      allTags.map((t) => (
        <button class="filter-btn" data-filter={t}>
          {t}
        </button>
      ))
    }
  </div>
  <select class="filter-select" id="archive-filter-select" aria-label="Filter posts by tag">
    <option value="all">All Posts</option>
    {allTags.map((t) => <option value={t}>{t}</option>)}
  </select>

  <!-- Archive list -->
  <main class="archive" id="archive">
    {
      years.map((year) => (
        <div class="year-group" id={`group-${year}`} data-year={year}>
          <div class="year-heading">
            {year}
            <span class="post-count" id={`count-${year}`}>
              {byYear[year].length}
            </span>
          </div>
          <ul class="post-list">
            {byYear[year].map((post) => (
              <a
                href={`/blog/${flatSlug(post.id)}`}
                class="post-row"
                data-tags={post.data.tags.join(",")}
              >
                <span class="post-date">{fmtDate(post.data.date, 'short')}</span>
                <div class="post-info">
                  <div class="post-title">{post.data.title}</div>
                  <div class="post-tags">
                    {post.data.tags.map((t) => (
                      <span class={`post-tag${t === post.data.primaryTag ? ' post-tag--primary' : ''}`}>{t}</span>
                    ))}
                  </div>
                </div>
                <div class="post-meta-right">
                  <span class="post-readtime">
                    {calcReadTime(post.body, post.data.readTime)}
                  </span>
                  <div class="post-arrow">
                    <svg viewBox="0 0 24 24">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </ul>
        </div>
      ))
    }

    <div class="empty-state" id="empty-state">
      <svg viewBox="0 0 24 24"
        ><circle cx="11" cy="11" r="8"></circle><line
          x1="21"
          y1="21"
          x2="16.65"
          y2="16.65"></line></svg
      >
      No posts match this filter.
    </div>
  </main>
</BlogLayout>

<style>
  /* ── Page header ── */
  .page-header {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2rem 2.5rem;
    border-bottom: 1px solid var(--border);
  }
  .page-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
  }
  .page-eyebrow::before {
    content: "";
    width: 22px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }
  .page-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 0.75rem;
  }
  .page-sub {
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ── Filter bar ── */
  .filter-bar {
    max-width: 860px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
  }
  .filter-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-right: 0.35rem;
  }
  .filter-btn {
    padding: 0.28rem 0.8rem;
    border-radius: 5px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    font-family: var(--font);
    transition: all 0.18s;
  }
  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .filter-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* ── Archive ── */
  .archive {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 2rem 6rem;
  }

  .year-group {
    margin-top: 3rem;
  }
  .year-group.hidden {
    display: none;
  }

  .year-heading {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .year-heading::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .post-count {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--muted);
    background: var(--tag-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1rem 0.45rem;
  }

  .post-list {
    list-style: none;
  }

  .post-row {
    display: grid;
    grid-template-columns: 90px 1fr auto;
    align-items: baseline;
    gap: 0 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    position: relative;
  }
  .post-row::before {
    content: "";
    position: absolute;
    left: -1rem;
    right: -1rem;
    top: 0;
    bottom: 0;
    border-radius: 8px;
    background: transparent;
    transition: background 0.18s;
    z-index: -1;
  }
  .post-row:hover::before {
    background: var(--bg);
  }
  .post-row:last-child {
    border-bottom: none;
  }
  .post-row.hidden {
    display: none;
  }

  .post-date {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    white-space: nowrap;
    letter-spacing: 0.02em;
  }

  .post-info {
    min-width: 0;
  }
  .post-title {
    font-size: 0.975rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
    margin-bottom: 0.3rem;
    transition: color 0.18s;
  }
  .post-row:hover .post-title {
    color: var(--accent);
  }

  .post-tags {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }
  .post-tag {
    font-size: 0.62rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: var(--tag-bg);
    color: var(--muted);
    border: 1px solid var(--border);
  }
  .post-tag--primary {
    background: var(--accent);
    color: #fff;
    border-color: var(--accent);
  }

  .post-meta-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .post-readtime {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--muted);
    white-space: nowrap;
  }

  .post-arrow {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    flex-shrink: 0;
    background: var(--tag-bg);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.18s,
      border-color 0.18s;
  }
  .post-row:hover .post-arrow {
    background: var(--accent);
    border-color: var(--accent);
  }
  .post-arrow svg {
    width: 12px;
    height: 12px;
    stroke: var(--muted);
    fill: none;
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 0.18s;
  }
  .post-row:hover .post-arrow svg {
    stroke: #fff;
  }

  /* ── Empty state ── */
  .empty-state {
    display: none;
    text-align: center;
    padding: 5rem 0;
    color: var(--muted);
    font-size: 0.9rem;
  }
  .empty-state.visible {
    display: block;
  }
  .empty-state svg {
    width: 32px;
    height: 32px;
    stroke: var(--border);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    display: block;
    margin: 0 auto 0.75rem;
  }

  .filter-select {
    display: none;
    max-width: 860px;
    width: calc(100% - 4rem);
    margin: 0 auto 1rem;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    border: 1.5px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 0.88rem;
    font-family: var(--font);
    appearance: none;
    cursor: pointer;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .filter-bar {
      display: none;
    }
    .filter-select {
      display: block;
    }
    .post-row {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
    }
    .post-date {
      grid-column: 1;
      grid-row: 1;
      font-size: 0.68rem;
      margin-bottom: 0.15rem;
    }
    .post-info {
      grid-column: 1;
      grid-row: 2;
    }
    .post-meta-right {
      grid-column: 2;
      grid-row: 1 / 3;
      align-self: center;
    }
    .post-readtime {
      display: none;
    }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  const groups = document.querySelectorAll<HTMLElement>(".year-group");
  const empty = document.getElementById("empty-state")!;

  function applyFilter(tag: string) {
    let total = 0;
    groups.forEach((group) => {
      const rows = group.querySelectorAll<HTMLElement>(".post-row");
      let visible = 0;
      rows.forEach((row) => {
        const show =
          tag === "all" || row.dataset.tags!.split(",").includes(tag);
        row.classList.toggle("hidden", !show);
        if (show) visible++;
      });
      group.classList.toggle("hidden", visible === 0);
      const badge = group.querySelector<HTMLElement>(".post-count");
      if (badge) badge.textContent = String(visible);
      total += visible;
    });
    empty.classList.toggle("visible", total === 0);
  }

  btns.forEach((btn) =>
    btn.addEventListener("click", () => {
      btns.forEach((b) => b.classList.remove("active"));
      btn.classList.add("active");
      applyFilter(btn.dataset.filter ?? "all");
    }),
  );

  document.getElementById("archive-filter-select")?.addEventListener("change", (e) =>
    applyFilter((e.target as HTMLSelectElement).value),
  );
</script>
