---
// src/pages/blog/topics/[slug].astro
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { flatSlug, fmtDate, calcReadTime } from "../../../lib/utils";
import { resolveCover } from "../../../lib/images";

const topicsMeta: Record<string, { description: string; iconPath: string; hue: string }> = {
  Terraform: {
    description: "Infrastructure as Code — provisioning, state management, modules, and real-world Terraform patterns for cloud platforms.",
    iconPath: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
    hue: "220",
  },
  SRE: {
    description: "Site Reliability Engineering — observability, incident response, on-call practices, and the reality of keeping production systems running.",
    iconPath: "M22 12h-4l-3 9L9 3l-3 9H2",
    hue: "160",
  },
  AI: {
    description: "Artificial Intelligence — language models, practical AI tooling, and what it actually means to build with AI in production.",
    iconPath: "M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01",
    hue: "280",
  },
};

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => !data.draft);

  const topicMap = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    if (!post.data.primaryTag) continue;
    const slug = post.data.primaryTag.toLowerCase().replace(/\s+/g, "-");
    if (!topicMap.has(slug)) topicMap.set(slug, []);
    topicMap.get(slug)!.push(post);
  }

  return [...topicMap.entries()].map(([slug, posts]) => ({
    params: { slug },
    props: {
      topicName: posts[0].data.primaryTag!,
      posts: posts.sort(
        (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
      ),
    },
  }));
}

const { topicName, posts } = Astro.props;

const meta = topicsMeta[topicName] ?? {
  description: `All posts tagged ${topicName}.`,
  iconPath: "M7 7h10v10H7z",
  hue: "220",
};

const totalReadMins = posts.reduce((acc, p) => {
  return acc + parseInt(calcReadTime(p.body, p.data.readTime));
}, 0);
---

<BlogLayout
  title={`isBhuvan / Topics / ${topicName}`}
  description={meta.description}
  crumbs={[
    { label: "Blog", href: "/blog" },
    { label: "Topics", href: "/blog/topics" },
    { label: topicName },
  ]}
>
  <!-- ═══ HERO ════════════════════════════════════════════════ -->
  <section class="topic-hero" style={`--hue: ${meta.hue}`}>
    <div class="th-grid-bg" aria-hidden="true"></div>
    <div class="th-inner">

      <div class="th-eyebrow">
        <svg viewBox="0 0 24 24"><path d={meta.iconPath} /></svg>
        Topic
      </div>

      <h1 class="th-title">{topicName}</h1>
      <p class="th-desc">{meta.description}</p>

      <div class="th-stats">
        <div class="th-stat">
          <svg viewBox="0 0 24 24">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20 M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          {posts.length} {posts.length === 1 ? "post" : "posts"}
        </div>
        <div class="th-stat-divider"></div>
        <div class="th-stat">
          <svg viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" />
            <polyline points="12 6 12 12 16 14" />
          </svg>
          ~{totalReadMins} min total
        </div>
        <div class="th-stat-divider"></div>
        <div class="th-stat">
          <svg viewBox="0 0 24 24">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <line x1="16" y1="2" x2="16" y2="6" />
            <line x1="8" y1="2" x2="8" y2="6" />
            <line x1="3" y1="10" x2="21" y2="10" />
          </svg>
          Latest: {fmtDate(posts[0]?.data.date)}
        </div>
      </div>

    </div>
  </section>

  <!-- ═══ POST GRID ════════════════════════════════════════════ -->
  <main class="main">
    <div class="wrap">

      <div class="section-label reveal">All {topicName} Posts</div>

      <div class="post-grid">
        {posts.map((post, i) => (
          <a href={`/blog/${flatSlug(post.id)}`} class="post-card reveal">
            <div class={`post-thumb${resolveCover(post.data.cover) ? " has-photo" : ""}`}>
              {resolveCover(post.data.cover) ? (
                <Image
                  src={resolveCover(post.data.cover)!}
                  alt={post.data.title}
                  class="post-thumb-img"
                  width={600}
                />
              ) : (
                <>
                  <svg class="post-thumb-pattern" viewBox="0 0 200 80" preserveAspectRatio="xMidYMid slice">
                    <defs>
                      <pattern id={`tp${i}`} x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
                        <circle cx="10" cy="10" r="1" fill="currentColor" opacity="0.35" />
                      </pattern>
                    </defs>
                    <rect width="200" height="80" fill={`url(#tp${i})`} />
                  </svg>
                  <svg class="post-thumb-icon" viewBox="0 0 24 24">
                    <path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z" />
                  </svg>
                </>
              )}
            </div>
            <div class="post-body">
              <div class="post-date">{fmtDate(post.data.date)}</div>
              <h3 class="post-title">{post.data.title}</h3>
              <p class="post-excerpt">{post.data.description}</p>
              <div class="post-footer">
                <div class="post-tags">
                  {post.data.tags.map((t) => (
                    <span class={`post-tag${t === post.data.primaryTag ? " post-tag--primary" : ""}`}>{t}</span>
                  ))}
                </div>
                <div class="post-arrow">
                  <svg viewBox="0 0 24 24">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="bottom-nudge reveal">
        <p>Looking for other topics?</p>
        <a href="/blog/topics" class="bottom-link">
          Browse all topics
          <svg viewBox="0 0 24 24">
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>

    </div>
  </main>
</BlogLayout>

<style>
  .wrap { max-width: var(--max-w); margin: 0 auto; padding: 0 2rem; }
  .main { padding: 3.5rem 0 6rem; }

  /* ════════════════════════
     HERO
  ════════════════════════ */
  .topic-hero {
    --hue: 220;
    position: relative;
    overflow: hidden;
    padding: 5rem 0 4rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }
  /* Per-topic accent top bar */
  .topic-hero::after {
    content: "";
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, hsl(var(--hue), 72%, 50%), hsl(var(--hue), 60%, 70%));
  }
  .th-grid-bg {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px; opacity: 0.3;
  }
  .th-inner {
    position: relative; z-index: 1;
    max-width: var(--max-w); margin: 0 auto; padding: 0 2rem;
  }
  .th-eyebrow {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 1.25rem;
  }
  .th-eyebrow::before {
    content: ''; display: inline-block; width: 24px; height: 2px;
    background: var(--accent); border-radius: 2px;
  }
  .th-eyebrow svg {
    width: 14px; height: 14px; stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }
  .th-title {
    font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800;
    line-height: 1.05; color: var(--text); letter-spacing: -0.03em; margin-bottom: 1.1rem;
  }
  .th-desc {
    font-size: 1rem; font-weight: 300; color: var(--muted);
    max-width: 580px; line-height: 1.8; margin-bottom: 2rem;
  }
  .th-stats {
    display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
  }
  .th-stat {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-size: 0.76rem; font-weight: 600; color: var(--muted);
    padding: 0.35rem 0.85rem; border-radius: 20px;
    background: var(--surface); border: 1px solid var(--border);
  }
  .th-stat svg {
    width: 13px; height: 13px; stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }
  .th-stat-divider { width: 1px; height: 18px; background: var(--border); }

  /* ════════════════════════
     SECTION LABEL
  ════════════════════════ */
  .section-label {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--muted); display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;
  }
  .section-label::after { content: ""; flex: 1; height: 1px; background: var(--border); }

  /* ════════════════════════
     BOTTOM NUDGE
  ════════════════════════ */
  .bottom-nudge {
    margin-top: 4rem; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
  }
  .bottom-nudge p { font-size: 0.9rem; color: var(--muted); }
  .bottom-link {
    display: inline-flex; align-items: center; gap: 0.45rem;
    font-size: 0.88rem; font-weight: 700; color: var(--accent);
    text-decoration: none; transition: gap 0.2s;
  }
  .bottom-link:hover { gap: 0.7rem; }
  .bottom-link svg {
    width: 14px; height: 14px; stroke: currentColor; fill: none;
    stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round;
  }

  /* ════════════════════════
     REVEAL
  ════════════════════════ */
  .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.5s ease, transform 0.5s ease; }
  .reveal.visible { opacity: 1; transform: none; }

  @media (max-width: 860px) {
    .post-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 640px) {
    .topic-hero { padding: 3rem 0 2.5rem; }
    .th-title { font-size: 2.2rem; }
    .th-stat-divider { display: none; }
    .post-grid { grid-template-columns: 1fr !important; }
    .wrap { padding: 0 1rem; }
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  }, { threshold: 0.05 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
