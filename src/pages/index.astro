---
// src/pages/index.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import { getCollection } from "astro:content";
import { homeContent } from "../data/homeContent.ts";
import { projects as allProjects } from "../data/siteContent";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 3);

import { flatSlug, fmtDate } from "../lib/utils";

const { reach } = homeContent;

const colors = ["var(--accent)", "#059669", "#d97706"];
const labels = ["Explore Project", "View Details", "View Details"];
const picks = [
  allProjects.find((p) => p.featured) ?? allProjects[0],
  allProjects.find((p) => !p.featured && p.tags.includes("Networking")) ??
    allProjects[1],
  allProjects.find((p) => !p.featured && p.tags.includes("Security")) ??
    allProjects[2],
];
const projects = picks.map((p, i) => ({
  num: String(i + 1).padStart(2, "0"),
  featured: i === 0,
  color: colors[i],
  title: p.title,
  desc: p.desc,
  tags: p.tags,
  href: p.href,
  label: labels[i],
}));

const marqueeItems = [
  "Azure AKS",
  "Terraform",
  "GitHub Actions",
  "Go / Golang",
  "ArgoCD",
  "Prometheus",
  "Grafana",
  "OpenTelemetry",
  "OPA / Rego",
  "Flux CD",
  "Helm 3",
  "Azure Policy",
  "Entra ID",
  "Key Vault",
  "Azure Monitor",
];

const siteUrl = Astro.site
  ? String(Astro.site).replace(/\/$/, "")
  : "https://isbhuvan.github.io";
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "isBhuvan",
  url: siteUrl,
  description:
    "Azure Cloud Engineer. Building resilient cloud infrastructure and writing about Kubernetes, Terraform, and platform engineering.",
  author: { "@type": "Person", name: "Bhuvan", url: siteUrl },
};
---

<BaseLayout
  title="isBhuvan — Azure Cloud Engineer"
  description="Azure Cloud Engineer. Building resilient cloud infrastructure and writing about Kubernetes, Terraform, and platform engineering."
  jsonLd={[websiteSchema]}
>
  <!-- ══ HERO ══ -->
  <Hero />

  <!-- ══ MARQUEE ══ -->
  <div class="marquee-track" aria-hidden="true">
    <div class="marquee-inner">
      {
        [...marqueeItems, ...marqueeItems].map((item) => (
          <span class="marquee-item">
            <span class="marquee-dot" />
            {item}
          </span>
        ))
      }
    </div>
  </div>

  <!-- ══ PROJECTS ══ -->
  <section class="home-sec projects-sec">
    <div class="home-inner">
      <div class="sec-hdr reveal">
        <div>
          <div class="sec-eyebrow">Selected Work</div>
          <h2 class="sec-title">
            Infrastructure<br /><em>at production scale</em>
          </h2>
        </div>
        <div class="sec-hdr-right">
          <p class="sec-intro">
            A selection of Azure platform engineering projects — AKS clusters,
            Terraform module registries, GitOps platforms, and Go-based tooling.
          </p>
          <a href="/projects" class="sec-link">
            View All Projects
            <svg viewBox="0 0 24 24" aria-hidden="true"
              ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                points="12 5 19 12 12 19"></polyline></svg
            >
          </a>
        </div>
      </div>

      <div class="projects-grid reveal">
        {
          projects.map((p) => (
            <a
              href={p.href}
              class={`proj-card${p.featured ? " proj-featured" : ""}`}
              style={`--pc: ${p.color}`}
            >
              <div class="proj-num">{p.num}</div>
              {p.featured && (
                <span class="proj-featured-label">Featured Project</span>
              )}
              <h3 class="proj-title">{p.title}</h3>
              <p class="proj-desc">{p.desc}</p>
              <div class="proj-tags">
                {p.tags.map((t) => (
                  <span class="proj-tag">{t}</span>
                ))}
              </div>
              <span class="proj-arrow">
                {p.label}
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <>
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </>
                </svg>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ══ WRITING ══ -->
  {
    recentPosts.length > 0 && (
      <section class="home-sec writing-sec">
        <div class="home-inner">
          <div class="sec-hdr reveal">
            <div>
              <div class="sec-eyebrow">isBhuvan — Writing</div>
              <h2 class="sec-title">
                Technical writing
                <>
                  <br />
                  <em>from the trenches</em>
                </>
              </h2>
            </div>
            <div class="sec-hdr-right">
              <p class="sec-intro">
                Deep-dives into Azure, Kubernetes internals, Terraform patterns,
                and Golang tooling — written for engineers who want to
                understand, not just copy.
              </p>
              <a href="/blog" class="sec-link">
                All Articles
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <>
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </>
                </svg>
              </a>
            </div>
          </div>

          <div class="posts-grid">
            {recentPosts.map((post, i) => (
              <a
                href={`/blog/${flatSlug(post.id)}`}
                class={`post-card${i === 0 ? " hero-post" : ""} reveal`}
              >
                {post.data.tags?.[0] && (
                  <span class="post-cat">{post.data.tags.join(" · ")}</span>
                )}
                <h3 class="post-title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="post-excerpt">{post.data.description}</p>
                )}
                <span class="post-arrow">Read Article</span>
                <div class="post-meta">
                  <span>{fmtDate(post.data.date, "short")}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ══ CONNECT ══ -->
  <section class="home-sec connect-sec">
    <div class="home-inner connect-inner">
      <div class="connect-eyebrow reveal">Let&rsquo;s Talk</div>
      <h2 class="connect-h reveal">Talk cloud<br /><em>engineering.</em></h2>
      <p class="connect-sub reveal">
        Writing about Azure, Kubernetes, Terraform, and Golang at isBhuvan. If
        you want to discuss cloud engineering, collaborate on open source, or
        talk about an article &mdash; reach out.
      </p>
      <div class="connect-chips reveal">
        {
          reach.socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener"
              class="connect-chip"
              style={`--cc: ${s.color}`}
            >
              <svg viewBox="0 0 24 24" class="chip-icon" set:html={s.icon} />
              <span>{s.name}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Shared ───────────────────────────────────────── */
  .home-sec {
    padding: 6rem 0;
  }

  .home-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Section header (2-col) */
  .sec-hdr {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-bottom: 3rem;
  }

  .sec-hdr-right {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-start;
  }

  .sec-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.7rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sec-eyebrow::before {
    content: "";
    display: inline-block;
    width: 20px;
    height: 1.5px;
    background: var(--accent);
  }

  .sec-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 400;
    line-height: 1.05;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .sec-title em {
    font-style: italic;
    color: var(--muted);
  }

  .sec-intro {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--muted);
  }

  .sec-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    transition: gap 0.18s;
  }

  .sec-link:hover {
    gap: 0.65rem;
  }

  .sec-link svg {
    width: 13px;
    height: 13px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Marquee ─────────────────────────────────────── */
  .marquee-track {
    overflow: hidden;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    padding: 0.8rem 0;
  }

  .marquee-inner {
    display: flex;
    width: max-content;
    animation: marquee 32s linear infinite;
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }

  .marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0 2rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }

  .marquee-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.5;
    flex-shrink: 0;
  }

  /* ── Projects ────────────────────────────────────── */
  .projects-sec {
    background: var(--bg);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .proj-card {
    background: var(--surface);
    padding: 2rem 2.2rem;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    position: relative;
    transition: background 0.2s;
  }

  .proj-card:hover {
    background: color-mix(in srgb, var(--pc) 4%, var(--surface));
  }

  .proj-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--pc, var(--accent));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .proj-card:hover::before {
    transform: scaleX(1);
  }

  .proj-card.proj-featured {
    grid-row: 1 / 3;
    padding: 2.5rem 2.8rem;
  }

  .proj-num {
    font-family: var(--serif);
    font-size: 3.5rem;
    color: var(--text);
    opacity: 0.05;
    line-height: 1;
    font-weight: 400;
  }

  .proj-featured-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--pc, var(--accent));
    background: color-mix(in srgb, var(--pc) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--pc) 25%, transparent);
    padding: 0.22rem 0.65rem;
    border-radius: 4px;
    width: fit-content;
  }

  .proj-title {
    font-family: var(--serif);
    font-size: clamp(1.3rem, 2.2vw, 1.75rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.2;
  }

  .proj-desc {
    font-size: 0.875rem;
    line-height: 1.75;
    color: var(--muted);
    flex: 1;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .proj-tag {
    font-family: var(--font-mono);
    font-size: 0.54rem;
    letter-spacing: 0.06em;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    color: var(--muted);
  }

  .proj-arrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--pc, var(--accent));
    margin-top: 0.25rem;
    transition: gap 0.18s;
  }

  .proj-card:hover .proj-arrow {
    gap: 0.65rem;
  }

  .proj-arrow svg {
    width: 12px;
    height: 12px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Skills ──────────────────────────────────────── */
  .skills-sec {
    background: var(--surface);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .skill-card {
    background: var(--bg);
    padding: 1.8rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 0.2s;
  }

  .skill-card:hover {
    background: color-mix(in srgb, var(--dc) 4%, var(--bg));
  }

  .skill-icon {
    font-size: 1.4rem;
    line-height: 1;
    margin-bottom: 0.25rem;
    transition: filter 0.2s;
    filter: grayscale(30%);
  }

  .skill-card:hover .skill-icon {
    filter: none;
  }

  .skill-name {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text);
  }

  .skill-tools {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    line-height: 1.85;
    color: var(--muted);
    flex: 1;
  }

  .skill-bar-track {
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    margin-top: 0.5rem;
    overflow: hidden;
  }

  .skill-bar-fill {
    height: 100%;
    width: 0;
    border-radius: 2px;
    background: linear-gradient(
      90deg,
      var(--dc),
      color-mix(in srgb, var(--dc) 60%, transparent)
    );
    transition: width 1.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skill-bar-fill.go {
    width: var(--w);
  }

  /* ── Writing / Blog ──────────────────────────────── */
  .writing-sec {
    background: var(--bg);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1.35fr 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .post-card {
    background: var(--surface);
    padding: 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s;
  }

  .post-card:hover {
    background: color-mix(in srgb, var(--accent) 3%, var(--surface));
  }

  .post-card.hero-post {
    padding: 2.4rem 2.4rem;
  }

  .post-cat {
    font-family: var(--font-mono);
    font-size: 0.56rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-title {
    font-family: var(--serif);
    font-size: 1.35rem;
    font-weight: 400;
    color: var(--text);
    line-height: 1.25;
    transition: color 0.18s;
  }

  .post-card.hero-post .post-title {
    font-size: 1.65rem;
  }

  .post-card:hover .post-title {
    color: var(--accent);
  }

  .post-excerpt {
    font-size: 0.87rem;
    line-height: 1.75;
    color: var(--muted);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-arrow {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.56rem;
    color: var(--muted);
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }

  /* ── Connect ──────────────────────────────────────── */
  .connect-sec {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .connect-inner {
    text-align: center;
  }

  .connect-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .connect-h {
    font-family: var(--serif);
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.02em;
    margin-bottom: 1.2rem;
  }

  .connect-h em {
    font-style: italic;
    color: var(--muted);
  }

  .connect-sub {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 2.5rem;
  }

  .connect-chips {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.65rem;
  }

  .connect-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 1.1rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    transition:
      border-color 0.18s,
      color 0.18s,
      background 0.18s,
      transform 0.15s;
  }

  .connect-chip:hover {
    border-color: var(--cc, var(--accent));
    color: var(--cc, var(--accent));
    background: color-mix(in srgb, var(--cc, var(--accent)) 6%, var(--bg));
    transform: translateY(-1px);
  }

  .chip-icon {
    width: 16px;
    height: 16px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 960px) {
    .sec-hdr {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }

    .proj-card.proj-featured {
      grid-row: auto;
    }
  }

  @media (max-width: 640px) {
    .home-sec {
      padding: 4rem 0;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .connect-chips {
      flex-direction: column;
      align-items: center;
    }

    .sec-hdr {
      margin-bottom: 2rem;
    }
  }
</style>

<script>
  // ── Reveal on scroll ────────────────────────────────
  const revObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e, i) => {
        if (e.isIntersecting) {
          setTimeout(() => e.target.classList.add("on"), i * 60);
          revObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0, rootMargin: "0px 0px -50px 0px" },
  );
  document.querySelectorAll(".reveal").forEach((el) => revObs.observe(el));
  setTimeout(() => {
    document
      .querySelectorAll(".reveal:not(.on)")
      .forEach((el) => el.classList.add("on"));
  }, 900);

  // ── Skill bar animation ─────────────────────────────
  const barObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target
            .querySelectorAll<HTMLElement>(".skill-bar-fill")
            .forEach((b) => b.classList.add("go"));
          barObs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.2 },
  );
  const grid = document.getElementById("skillsGrid");
  if (grid) barObs.observe(grid);
</script>
