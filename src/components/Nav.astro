---
const path = Astro.url.pathname;
---

<!-- Desktop nav -->
<nav class="navbar-top" id="navbar-top">
  <div class="navbar-inner">
    <div class="navbar-brand-area">
      <a class="navbar-brand-custom" href="/"
        ><span class="nav-is">is</span>Bhuvan</a
      >
    </div>
    <div class="nav-right">
      <ul class="nav-links" id="desktop-nav">
        <li>
          <a
            href="/projects"
            class={path.startsWith("/projects") ? "active" : ""}>Work</a
          >
        </li>
        <li>
          <a href="/blog" class={path.startsWith("/blog") ? "active" : ""}
            >Blog</a
          >
        </li>
        <li>
          <a href="/about" class={path.startsWith("/about") ? "active" : ""}
            >About</a
          >
        </li>
      </ul>

      <div class="nav-actions">
        <button
          class="nav-icon-btn search-btn"
          id="search-open-btn"
          aria-label="Search"
          title="Search (⌘K)"
        >
          <kbd class="search-kbd-hint">⌘K</kbd>
          <svg viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>

        <button
          class="nav-icon-btn theme-btn"
          id="theme-btn"
          aria-label="Toggle theme"
          title="Toggle theme"
        >
          <svg id="theme-icon" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile top header -->
<header class="navbar-mobile-top" id="navbar-mobile-top">
  <a class="mobile-brand" href="/"><span class="nav-is">is</span>Bhuvan</a>
  <div class="mobile-top-actions">
    <button
      class="mobile-action-btn"
      id="mobile-theme-btn"
      aria-label="Toggle theme"
      title="Toggle theme"
    >
      <svg id="mobile-theme-icon" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="5"></circle>
        <line x1="12" y1="1" x2="12" y2="3"></line>
        <line x1="12" y1="21" x2="12" y2="23"></line>
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
        <line x1="1" y1="12" x2="3" y2="12"></line>
        <line x1="21" y1="12" x2="23" y2="12"></line>
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
      </svg>
    </button>
    <button
      class="mobile-action-btn"
      id="mobile-search-open-btn"
      aria-label="Search"
    >
      <svg viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile bottom nav -->
<nav class="navbar-bottom">
  <div class="bottom-nav-inner">
    <a href="/" class={path === "/" ? "active" : ""}>
      <svg class="nav-icon" viewBox="0 0 24 24"
        ><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V9.5z"
        ></path><path d="M9 21V12h6v9"></path></svg
      >
      Home
    </a>
    <a href="/projects" class={path.startsWith("/projects") ? "active" : ""}>
      <svg class="nav-icon" viewBox="0 0 24 24"
        ><rect x="3" y="3" width="18" height="14" rx="2"></rect><path
          d="M8 21h8M12 17v4"></path></svg
      >
      Work
    </a>
    <a href="/blog" class={path.startsWith("/blog") ? "active" : ""}>
      <svg class="nav-icon" viewBox="0 0 24 24"
        ><path d="M4 4h16v12H4z"></path><path d="M8 20h8M12 16v4"></path><path
          d="M8 9h8M8 12h5"></path></svg
      >
      Blog
    </a>
    <a href="/about" class={path.startsWith("/about") ? "active" : ""}>
      <svg class="nav-icon" viewBox="0 0 24 24"
        ><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle
          cx="12"
          cy="7"
          r="4"></circle></svg
      >
      About
    </a>
  </div>
</nav>

<!-- Search modal -->
<div
  class="search-overlay"
  id="search-overlay"
  role="dialog"
  aria-modal="true"
  aria-label="Search"
>
  <div class="search-modal">
    <div class="search-modal-header">
      <div class="search-modal-input-wrap">
        <svg class="search-input-icon" viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          type="search"
          id="pagefind-search-input"
          class="search-modal-input"
          placeholder="Search posts, references, projects…"
          autocomplete="off"
          spellcheck="false"
        />
        <button
          class="search-clear-btn"
          id="search-clear-btn"
          aria-label="Clear"
        >
          <svg viewBox="0 0 24 24">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
      <button
        class="search-close-btn"
        id="search-close-btn"
        aria-label="Close search"
      >
        <kbd>Esc</kbd>
      </button>
    </div>
    <div class="search-modal-body" id="search-results-container">
      <div class="search-empty-state" id="search-empty-state">
        <svg viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <p>Type to search across all content</p>
      </div>
    </div>
    <div class="search-modal-footer">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> open</span>
      <span><kbd>Esc</kbd> close</span>
      <span class="search-powered"
        >Powered by <a
          href="https://pagefind.app"
          target="_blank"
          rel="noopener">Pagefind</a
        ></span
      >
    </div>
  </div>
</div>

<style>
  /* ── Desktop nav ── */
  .navbar-top {
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    height: 64px;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.3s,
      border-color 0.3s,
      box-shadow 0.3s;
  }

  .navbar-top.scrolled {
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.07);
  }

  .navbar-inner {
    width: 100%;
    max-width: 1100px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }


  .navbar-brand-area {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .navbar-brand-custom {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
    letter-spacing: normal;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 0.75rem;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-links a.active {
    color: var(--accent);
    border-bottom: 2px solid var(--accent);
    padding-bottom: calc(0.4rem - 2px);
  }

  /* ── Icon actions group (search + theme) ── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: 1rem;
    padding-left: 1rem;
    border-left: 1px solid var(--border);
  }

  .nav-icon-btn {
    width: 32px;
    height: 32px;
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition: color 0.2s;
    padding: 0;
  }

  .nav-icon-btn svg {
    width: 15px;
    height: 15px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nav-icon-btn:hover {
    color: var(--text);
  }

  /* ── Search button with ⌘K hint ── */
  .search-btn {
    width: auto;
    gap: 0.35rem;
    padding: 0 0.5rem;
  }

  .search-kbd-hint {
    font-size: 0.6rem;
    font-weight: 600;
    font-family: var(--font);
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    background: var(--tag-bg);
    border: 1px solid var(--border);
    color: var(--muted);
    line-height: 1.5;
    pointer-events: none;
  }

  /* ── Theme toggle ── */
  /* ── Mobile top header ── */
  .navbar-mobile-top {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 56px;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
    z-index: 1000;
    padding: 0 1rem;
    align-items: center;
    justify-content: space-between;
    transform: translateY(0);
    transition:
      transform 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.3s,
      border-color 0.3s,
      box-shadow 0.3s;
  }

  .navbar-mobile-top.scrolled {
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.07);
  }

  .navbar-mobile-top.nav-hidden {
    transform: translateY(-100%);
  }

  .mobile-brand {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--text);
    text-decoration: none;
    letter-spacing: normal;
  }

  .mobile-top-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .mobile-action-btn {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--tag-bg);
    border: 1px solid var(--border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s,
      border-color 0.2s;
    padding: 0;
    color: var(--muted);
  }

  .mobile-action-btn:hover {
    background: rgba(37, 99, 235, 0.08);
    border-color: var(--accent);
    color: var(--accent);
  }

  .mobile-action-btn svg {
    width: 17px;
    height: 17px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Mobile bottom nav ── */
  .navbar-bottom {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg);
    border-top: 1px solid var(--border);
    height: 62px;
    z-index: 1000;
    transform: translateY(0);
    transition:
      transform 0.32s cubic-bezier(0.16, 1, 0.3, 1),
      background 0.3s,
      border-color 0.3s;
  }

  .navbar-bottom.nav-hidden {
    transform: translateY(100%);
  }

  .bottom-nav-inner {
    display: flex;
    height: 100%;
  }

  .bottom-nav-inner a {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-decoration: none;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    gap: 3px;
    transition: color 0.2s;
    position: relative;
    padding: 0 2px;
  }

  .bottom-nav-inner a::before {
    content: "";
    position: absolute;
    top: 6px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .bottom-nav-inner a:hover,
  .bottom-nav-inner a.active {
    color: var(--accent);
  }

  .bottom-nav-inner a:hover::before,
  .bottom-nav-inner a.active::before {
    opacity: 1;
  }

  .nav-icon {
    width: 17px;
    height: 17px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── Search modal overlay ── */
  .search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    z-index: 2000;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 5rem 1rem 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.18s ease;
    backdrop-filter: blur(3px);
  }

  .search-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  .search-modal {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    width: 100%;
    max-width: 640px;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    transform: translateY(-12px);
    transition: transform 0.18s ease;
  }

  .search-overlay.open .search-modal {
    transform: translateY(0);
  }

  .search-modal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .search-modal-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 0.75rem;
    transition: border-color 0.2s;
  }

  .search-modal-input-wrap:focus-within {
    border-color: var(--accent);
  }

  .search-input-icon {
    width: 15px;
    height: 15px;
    stroke: var(--muted);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    flex-shrink: 0;
  }

  .search-modal-input {
    flex: 1;
    border: none;
    background: transparent;
    font-size: 0.95rem;
    color: var(--text);
    font-family: var(--font);
    padding: 0.65rem 0;
    outline: none;
    min-width: 0;
  }

  .search-modal-input::placeholder {
    color: var(--muted);
    opacity: 0.7;
  }

  /* hide browser-native clear button */
  .search-modal-input::-webkit-search-cancel-button {
    display: none;
  }

  .search-clear-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    color: var(--muted);
    line-height: 0;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .search-clear-btn:hover {
    color: var(--text);
  }

  .search-clear-btn svg {
    width: 14px;
    height: 14px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
  }

  .search-clear-btn.visible {
    display: flex;
  }

  .search-close-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    padding: 0.3rem 0.5rem;
    color: var(--muted);
    font-family: var(--font);
    font-size: 0.7rem;
    transition:
      border-color 0.15s,
      color 0.15s;
    white-space: nowrap;
  }

  .search-close-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .search-close-btn kbd {
    font-family: inherit;
  }

  /* Results area */
  .search-modal-body {
    min-height: 200px;
    max-height: 480px;
    overflow-y: auto;
    padding: 0.5rem;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .search-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 3rem 2rem;
    color: var(--muted);
  }

  .search-empty-state svg {
    width: 32px;
    height: 32px;
    stroke: var(--border);
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
  }

  .search-empty-state p {
    font-size: 0.85rem;
    margin: 0;
  }

  /* Pagefind result items — :global() because they are injected via innerHTML */
  :global(.search-result-item) {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.8rem 0.9rem;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition:
      background 0.15s,
      border-color 0.15s;
    cursor: pointer;
    border: 1px solid transparent;
    position: relative;
  }

  :global(.search-result-item:hover),
  :global(.search-result-item.focused) {
    background: rgba(37, 99, 235, 0.06);
    border-color: var(--border);
  }

  :global(.search-result-item.focused) {
    border-color: rgba(37, 99, 235, 0.3);
    background: rgba(37, 99, 235, 0.06);
  }

  :global(.search-result-meta) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.1rem;
  }

  :global(.search-result-section) {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.15);
    flex-shrink: 0;
  }

  :global(.search-result-url) {
    font-size: 0.68rem;
    color: var(--muted);
    font-family: "Courier New", monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0.75;
  }

  :global(.search-result-title) {
    font-size: 0.94rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1.35;
  }

  :global(.search-result-item:hover .search-result-title),
  :global(.search-result-item.focused .search-result-title) {
    color: var(--accent);
  }

  :global(.search-result-excerpt) {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-top: 0.1rem;
  }

  :global(.search-result-excerpt mark) {
    background: rgba(37, 99, 235, 0.14);
    color: var(--accent);
    border-radius: 2px;
    padding: 0 2px;
    font-style: normal;
    font-weight: 600;
  }

  :global(.search-no-results) {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2.5rem 2rem;
    color: var(--muted);
    font-size: 0.85rem;
    text-align: center;
  }

  :global(.search-no-results code) {
    font-family: "Courier New", monospace;
    font-size: 0.8rem;
    background: var(--tag-bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
    color: var(--accent);
  }

  :global(.search-results-divider) {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.4rem 0.9rem 0.3rem;
    opacity: 0.55;
  }

  /* Footer */
  .search-modal-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
    flex-wrap: wrap;
  }

  .search-modal-footer span {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.7rem;
    color: var(--muted);
  }

  .search-modal-footer kbd {
    font-size: 0.65rem;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: inherit;
    line-height: 1.6;
  }

  .search-powered {
    margin-left: auto;
    font-size: 0.68rem;
    color: var(--muted);
    opacity: 0.6;
  }

  .search-powered a {
    color: var(--accent);
    text-decoration: none;
  }


  @media (max-width: 768px) {
    .navbar-top {
      display: none;
    }

    .navbar-mobile-top {
      display: flex;
    }

    .navbar-bottom {
      display: block;
    }

    .search-overlay {
      padding: 5rem 0.75rem 1rem;
      align-items: flex-start;
    }

    .search-modal-footer span:not(.search-powered) {
      display: none;
    }
  }
</style>

<script>
  // ── Open / close search modal ──
  const overlay = document.getElementById("search-overlay")!;
  const input = document.getElementById(
    "pagefind-search-input",
  ) as HTMLInputElement;
  const clearBtn = document.getElementById("search-clear-btn")!;
  const resultsContainer = document.getElementById("search-results-container")!;
  const emptyState = document.getElementById("search-empty-state")!;

  let pagefindLoaded = false;
  let pagefind: any = null;
  let resultLinks: HTMLAnchorElement[] = [];
  let focusedIdx = -1;
  let debounceTimer: ReturnType<typeof setTimeout>;

  function openSearch() {
    overlay.classList.add("open");
    document.body.style.overflow = "hidden";
    setTimeout(() => input.focus(), 60);
    if (!pagefindLoaded) loadPagefind();
  }

  function closeSearch() {
    overlay.classList.remove("open");
    document.body.style.overflow = "";
    input.value = "";
    clearBtn.classList.remove("visible");
    showEmptyState();
    focusedIdx = -1;
    resultLinks = [];
  }

  // Trigger buttons
  document
    .getElementById("search-open-btn")
    ?.addEventListener("click", openSearch);
  document
    .getElementById("mobile-search-open-btn")
    ?.addEventListener("click", openSearch);
  document
    .getElementById("search-close-btn")
    ?.addEventListener("click", closeSearch);

  // ── Mobile nav show / hide on scroll ──────────────────────────
  const mobileTop = document.getElementById("navbar-mobile-top");
  const bottomNav = document.querySelector<HTMLElement>(".navbar-bottom");

  let lastY = 0;
  let ticking = false;
  let autoHideTimer: ReturnType<typeof setTimeout> | null = null;
  const SCROLL_THRESHOLD = 8; // px of scroll movement before reacting
  const AT_TOP_THRESHOLD = 12; // px from top considered "at top"
  const AUTO_HIDE_MS = 3000; // ms before auto-hiding after scroll-up reveal

  function showMobileNavs() {
    clearTimeout(autoHideTimer!);
    mobileTop?.classList.remove("nav-hidden");
    bottomNav?.classList.remove("nav-hidden");
  }

  function hideMobileNavs() {
    clearTimeout(autoHideTimer!);
    mobileTop?.classList.add("nav-hidden");
    bottomNav?.classList.add("nav-hidden");
  }

  function scheduleAutoHide() {
    clearTimeout(autoHideTimer!);
    autoHideTimer = setTimeout(() => {
      if (window.scrollY > AT_TOP_THRESHOLD) hideMobileNavs();
    }, AUTO_HIDE_MS);
  }

  window.addEventListener(
    "scroll",
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;

        // Scroll shadow on top bar
        mobileTop?.classList.toggle("scrolled", y > 8);

        if (y <= AT_TOP_THRESHOLD) {
          // At top → always show
          showMobileNavs();
        } else if (y > lastY + SCROLL_THRESHOLD) {
          // Scrolling down → hide immediately
          hideMobileNavs();
        } else if (y < lastY - SCROLL_THRESHOLD) {
          // Scrolling up → show, then auto-hide after timeout
          showMobileNavs();
          scheduleAutoHide();
        }

        lastY = y;
        ticking = false;
      });
    },
    { passive: true },
  );

  overlay.addEventListener("click", (e) => {
    if (e.target === overlay) closeSearch();
  });

  // Keyboard shortcuts
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      overlay.classList.contains("open") ? closeSearch() : openSearch();
    }
    if (e.key === "Escape" && overlay.classList.contains("open")) {
      closeSearch();
    }
    if (overlay.classList.contains("open")) {
      if (e.key === "ArrowDown") {
        e.preventDefault();
        moveFocus(1);
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        moveFocus(-1);
      } else if (e.key === "Enter" && focusedIdx >= 0) {
        resultLinks[focusedIdx]?.click();
      }
    }
  });

  function moveFocus(dir: number) {
    if (!resultLinks.length) return;
    resultLinks[focusedIdx]?.classList.remove("focused");
    resultLinks[focusedIdx]?.setAttribute("aria-selected", "false");
    focusedIdx = Math.max(
      0,
      Math.min(resultLinks.length - 1, focusedIdx + dir),
    );
    resultLinks[focusedIdx]?.classList.add("focused");
    resultLinks[focusedIdx]?.setAttribute("aria-selected", "true");
    resultLinks[focusedIdx]?.scrollIntoView({ block: "nearest" });
  }

  // Clear button
  input.addEventListener("input", () => {
    clearBtn.classList.toggle("visible", input.value.length > 0);
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => runSearch(input.value.trim()), 220);
  });
  clearBtn.addEventListener("click", () => {
    input.value = "";
    clearBtn.classList.remove("visible");
    showEmptyState();
    input.focus();
  });

  function showEmptyState() {
    resultsContainer.innerHTML = "";
    resultsContainer.appendChild(emptyState);
  }

  // ── Load Pagefind lazily ──
  async function loadPagefind() {
    if (pagefindLoaded) return;
    try {
      // @ts-ignore
      pagefind = await import(/* @vite-ignore */ "/pagefind/pagefind.js");
      await pagefind.options({ baseUrl: "/" });
      pagefindLoaded = true;
    } catch {
      // dev mode: pagefind isn't generated yet — show a hint
      resultsContainer.innerHTML = `<div class="search-no-results">
        <span>Search index not built yet.</span>
        <span style="font-size:0.75rem;opacity:0.6">Run <code>npm run build</code> to generate the index.</span>
      </div>`;
    }
  }

  // ── Run search ──
  async function runSearch(query: string) {
    if (!query) {
      showEmptyState();
      return;
    }
    if (!pagefindLoaded) {
      await loadPagefind();
      if (!pagefindLoaded) return;
    }

    const search = await pagefind.search(query);
    const results = await Promise.all(
      search.results.slice(0, 10).map((r: any) => r.data()),
    );

    resultsContainer.innerHTML = "";
    focusedIdx = -1;
    resultLinks = [];

    if (!results.length) {
      resultsContainer.innerHTML = `<div class="search-no-results">No results for "<strong>${escHtml(query)}</strong>"</div>`;
      return;
    }

    resultsContainer.innerHTML = `<div class="search-results-divider">${results.length} result${results.length === 1 ? "" : "s"}</div>`;

    results.forEach((r: any) => {
      const section = sectionFromUrl(r.url);
      const link = document.createElement("a");
      link.href = r.url;
      link.className = "search-result-item";
      link.setAttribute("role", "option");
      link.setAttribute("aria-selected", "false");
      link.innerHTML = `
        <div class="search-result-meta">
          ${section ? `<span class="search-result-section">${escHtml(section)}</span>` : ""}
          <span class="search-result-url">${escHtml(r.url)}</span>
        </div>
        <div class="search-result-title">${escHtml(r.meta?.title ?? r.url)}</div>
        ${r.excerpt ? `<div class="search-result-excerpt">${r.excerpt}</div>` : ""}
      `;
      link.addEventListener("click", closeSearch);
      resultsContainer.appendChild(link);
      resultLinks.push(link);
    });
  }

  function sectionFromUrl(url: string): string {
    const seg = url.replace(/^\//, "").split("/")[0];
    const map: Record<string, string> = {
      blog: "Blog",
      references: "Docs",
      projects: "Work",
      about: "About",
    };
    return map[seg] ?? seg;
  }

  function escHtml(s: string) {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;");
  }
</script>
