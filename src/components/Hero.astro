---
// src/components/Hero.astro

const codeHtml = [
  '<span class="t-c"># Azure AKS · Terraform</span>',
  '',
  '<span class="t-k">resource</span> <span class="t-s">"azurerm_kubernetes_cluster"</span> <span class="t-s">"prod"</span> {',
  '  name                = <span class="t-s">"prod-aks-eastus"</span>',
  '  resource_group_name = <span class="t-a">var</span>.rg_name',
  '  location            = <span class="t-s">"eastus"</span>',
  '  kubernetes_version  = <span class="t-s">"1.29"</span>',
  '',
  '  <span class="t-k">default_node_pool</span> {',
  '    name       = <span class="t-s">"system"</span>',
  '    node_count = <span class="t-n">3</span>',
  '    vm_size    = <span class="t-s">"Standard_D4s_v5"</span>',
  '  }',
  '  <span class="t-k">identity</span> { type = <span class="t-s">"SystemAssigned"</span> }',
  '}',
  '',
  '<span class="t-c">$ terraform apply -auto-approve</span>',
  '<span class="t-ok">✓ azurerm_kubernetes_cluster.prod created</span>',
  '<span class="t-ok">✓ 32 resources · 4m 18s</span>',
  '<span class="t-c">$ </span><span class="t-cursor">_</span>',
].join('\n');
---

<section id="hero">
  <div class="hero-bg-grid" aria-hidden="true"></div>
  <div class="hero-watermark" aria-hidden="true">Azure</div>

  <div class="hero-inner">
    <!-- LEFT -->
    <div class="hero-left">
      <p class="hero-kicker">isBhuvan &middot; Bengaluru, India</p>

      <h1 class="hero-h1">
        Azure<br /><em>Cloud</em><br />
        <span class="hero-acc">Engineer.</span>
      </h1>

      <div class="hero-pills">
        <span class="hero-pill hi">AKS</span>
        <span class="hero-pill hi">Terraform</span>
        <span class="hero-pill hi">GitHub Actions</span>
        <span class="hero-pill hi">Golang</span>
        <span class="hero-pill">ArgoCD</span>
        <span class="hero-pill">Prometheus</span>
        <span class="hero-pill">OPA</span>
      </div>

      <p class="hero-desc">
        Building cloud-native infrastructure on Azure &mdash; Kubernetes platforms,
        Terraform module registries, GitOps pipelines, and Go-based operators.
        Writing about what I learn at <strong>isBhuvan</strong>.
      </p>

      <div class="hero-ctas">
        <a href="/projects" class="hero-btn-solid">View Projects</a>
        <a href="/blog" class="hero-btn-outline">
          Read the Blog
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <div class="hero-stats">
        <div class="hstat">
          <div class="hstat-num">7<sup>+</sup></div>
          <div class="hstat-lbl">Yrs on Azure</div>
        </div>
        <div class="hstat">
          <div class="hstat-num">40<sup>+</sup></div>
          <div class="hstat-lbl">Projects</div>
        </div>
        <div class="hstat">
          <div class="hstat-num">9</div>
          <div class="hstat-lbl">Certs</div>
        </div>
        <div class="hstat">
          <div class="hstat-num">20<sup>+</sup></div>
          <div class="hstat-lbl">Articles</div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Terminal -->
    <div class="hero-right">
      <div class="terminal">
        <div class="terminal-bar">
          <span class="t-dot t-red"></span>
          <span class="t-dot t-amber"></span>
          <span class="t-dot t-green"></span>
          <span class="terminal-title">main.tf &mdash; prod-aks</span>
        </div>
        <pre class="terminal-body" set:html={codeHtml}></pre>
        <div class="terminal-badges">
          <span class="t-badge ok">3 Nodes Ready</span>
          <span class="t-badge">AKS 1.29</span>

          <span class="t-badge ok">GitOps Active</span>
        </div>
      </div>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <svg viewBox="0 0 24 24">
      <line x1="12" y1="5" x2="12" y2="19"/>
      <polyline points="19 12 12 19 5 12"/>
    </svg>
    Scroll
  </div>
</section>

<style>
  /* ── Layout ────────────────────────────────────────── */
  #hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-bg-grid {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 52px 52px;
    opacity: 0.45;
  }

  .hero-watermark {
    position: absolute;
    right: -1rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--serif);
    font-size: clamp(8rem, 22vw, 18rem);
    font-weight: 700;
    color: var(--text);
    opacity: 0.025;
    pointer-events: none;
    user-select: none;
    letter-spacing: -0.04em;
    white-space: nowrap;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: var(--max-w);
    width: 100%;
    margin: 0 auto;
    padding: 6rem 2rem 4rem;
    display: grid;
    grid-template-columns: 1fr 460px;
    gap: 4rem;
    align-items: center;
  }

  /* ── Left column ───────────────────────────────────── */
  .hero-left {
    animation: heroUp 0.9s var(--ease, cubic-bezier(.16,1,.3,1)) both 0.1s;
  }

  @keyframes heroUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: none; }
  }

  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .hero-kicker::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1.5px;
    background: var(--accent);
    flex-shrink: 0;
  }

  .hero-h1 {
    font-family: var(--serif);
    font-size: clamp(3.8rem, 7.5vw, 7.5rem);
    font-weight: 400;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 1.4rem;
  }
  .hero-h1 em {
    font-style: italic;
    color: var(--muted);
  }
  .hero-acc {
    color: var(--accent);
  }

  /* Pills */
  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
    animation: heroUp 0.8s var(--ease, cubic-bezier(.16,1,.3,1)) both 0.35s;
  }
  .hero-pill {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    padding: 0.28rem 0.7rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    color: var(--muted);
    white-space: nowrap;
  }
  .hero-pill.hi {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 35%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }

  /* Description */
  .hero-desc {
    font-size: clamp(0.92rem, 1.6vw, 1.05rem);
    line-height: 1.72;
    color: var(--muted);
    max-width: 520px;
    margin-bottom: 1.8rem;
    animation: heroUp 0.8s var(--ease, cubic-bezier(.16,1,.3,1)) both 0.45s;
  }
  .hero-desc strong {
    color: var(--text);
    font-weight: 600;
  }

  /* CTAs */
  .hero-ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2.4rem;
    animation: heroUp 0.8s var(--ease, cubic-bezier(.16,1,.3,1)) both 0.55s;
  }
  .hero-btn-solid {
    background: var(--text);
    color: var(--bg);
    padding: 0.75rem 1.8rem;
    border-radius: 8px;
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity 0.2s, transform 0.15s;
  }
  .hero-btn-solid:hover { opacity: 0.85; transform: translateY(-1px); }

  .hero-btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--muted);
    padding: 0.75rem 0;
    font-size: 0.84rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s, gap 0.2s;
  }
  .hero-btn-outline:hover { color: var(--accent); gap: 0.7rem; }
  .hero-btn-outline svg {
    width: 15px; height: 15px;
    stroke: currentColor; fill: none;
    stroke-width: 2.2; stroke-linecap: round; stroke-linejoin: round;
  }

  /* Stats */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 0;
    width: fit-content;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    animation: fadeIn 1s var(--ease, cubic-bezier(.16,1,.3,1)) both 0.65s;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

  .hstat {
    padding: 0.9rem 1.4rem;
    text-align: center;
    border-right: 1px solid var(--border);
    background: var(--surface);
  }
  .hstat:last-child { border-right: none; }

  .hstat-num {
    font-family: var(--serif);
    font-size: 1.9rem;
    color: var(--text);
    line-height: 1;
    font-weight: 400;
  }
  .hstat-num sup {
    font-size: 0.7em;
    vertical-align: super;
    color: var(--accent);
  }
  .hstat-lbl {
    font-family: var(--font-mono);
    font-size: 0.52rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.25rem;
  }

  /* ── Terminal (right column) ───────────────────────── */
  .hero-right {
    animation: fadeIn 1s var(--ease, cubic-bezier(.16,1,.3,1)) both 0.5s;
  }

  .terminal {
    background: #0f1117;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(0,0,0,0.18), 0 4px 16px rgba(0,0,0,0.12);
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.75rem 1rem;
    background: #161b22;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .t-dot {
    width: 11px; height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .t-red   { background: #ff5f57; }
  .t-amber { background: #febc2e; }
  .t-green { background: #28c840; }

  .terminal-title {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.04em;
  }

  .terminal-body {
    margin: 0;
    padding: 1.4rem 1.6rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.75;
    color: #a8b8d0;
    overflow-x: auto;
    white-space: pre;
  }

  /* Terminal syntax colors */
  .terminal-body :global(.t-c)  { color: #55616e; }
  .terminal-body :global(.t-k)  { color: #c792ea; }
  .terminal-body :global(.t-s)  { color: #c3e88d; }
  .terminal-body :global(.t-n)  { color: #f78c6c; }
  .terminal-body :global(.t-a)  { color: #82aaff; }
  .terminal-body :global(.t-ok) { color: #c3e88d; }
  .terminal-body :global(.t-cursor) {
    display: inline-block;
    width: 0.55em;
    height: 1em;
    background: #82aaff;
    vertical-align: text-bottom;
    animation: blink 1.2s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  .terminal-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding: 0.75rem 1.2rem;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .t-badge {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.06em;
    padding: 0.22rem 0.6rem;
    border-radius: 4px;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.45);
    background: rgba(255,255,255,0.04);
  }
  .t-badge.ok {
    color: #c3e88d;
    border-color: rgba(195,232,141,0.25);
    background: rgba(195,232,141,0.06);
  }

  /* ── Terminal light theme ───────────────────────── */
  :global([data-theme="light"]) .terminal {
    background: #f6f8fa;
    border-color: rgba(0,0,0,0.1);
    box-shadow: 0 24px 60px rgba(0,0,0,0.07), 0 4px 16px rgba(0,0,0,0.05);
  }
  :global([data-theme="light"]) .terminal-bar {
    background: #eaeef2;
    border-bottom-color: rgba(0,0,0,0.08);
  }
  :global([data-theme="light"]) .terminal-title {
    color: rgba(0,0,0,0.38);
  }
  :global([data-theme="light"]) .terminal-body {
    color: #24292f;
  }
  :global([data-theme="light"]) .terminal-body :global(.t-c)  { color: #6e7781; }
  :global([data-theme="light"]) .terminal-body :global(.t-k)  { color: #8250df; }
  :global([data-theme="light"]) .terminal-body :global(.t-s)  { color: #0a3069; }
  :global([data-theme="light"]) .terminal-body :global(.t-n)  { color: #0550ae; }
  :global([data-theme="light"]) .terminal-body :global(.t-a)  { color: #953800; }
  :global([data-theme="light"]) .terminal-body :global(.t-ok) { color: #1a7f37; }
  :global([data-theme="light"]) .terminal-body :global(.t-cursor) {
    background: #0969da;
  }
  :global([data-theme="light"]) .terminal-badges {
    border-top-color: rgba(0,0,0,0.08);
  }
  :global([data-theme="light"]) .t-badge {
    border-color: rgba(0,0,0,0.1);
    color: rgba(0,0,0,0.45);
    background: rgba(0,0,0,0.03);
  }
  :global([data-theme="light"]) .t-badge.ok {
    color: #1a7f37;
    border-color: rgba(26,127,55,0.25);
    background: rgba(26,127,55,0.06);
  }

  /* ── Scroll hint ─────────────────────────────────── */
  .hero-scroll {
    position: absolute;
    bottom: 1.8rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 5px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    animation: scrollBounce 2.2s ease-in-out infinite;
  }
  .hero-scroll svg {
    width: 16px; height: 16px;
    stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
  }
  @keyframes scrollBounce {
    0%,100% { transform: translateX(-50%) translateY(0); }
    50%      { transform: translateX(-50%) translateY(5px); }
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 1100px) {
    .hero-inner {
      grid-template-columns: 1fr 400px;
      gap: 2.5rem;
    }
  }
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      padding: 5rem 1.5rem 3rem;
    }
    .hero-right { display: none; }
    .hero-watermark { display: none; }
    .hero-h1 { font-size: clamp(3rem, 12vw, 5rem); }
    .hero-stats { grid-template-columns: repeat(2, auto); }
    .hstat:nth-child(2) { border-right: 1px solid var(--border); }
    .hstat:nth-child(3) { border-top: 1px solid var(--border); }
    .hstat:nth-child(4) { border-top: 1px solid var(--border); }
  }
  @media (max-width: 480px) {
    .hero-ctas { flex-direction: column; align-items: flex-start; }
    .hero-stats { grid-template-columns: repeat(2, 1fr); width: 100%; }
  }
</style>
