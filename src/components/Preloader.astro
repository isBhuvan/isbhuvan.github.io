---

<div id="preloader">
  <div class="preloader-logo"><span class="nav-is">is</span>Bhuvan</div>
  <div class="preloader-bar-wrap">
    <div class="preloader-bar"></div>
  </div>
  <div class="preloader-label">Loading</div>
</div>

<style>
  #preloader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    transition:
      opacity 0.6s ease,
      visibility 0.6s ease;
  }

  :global([data-theme="dark"]) #preloader {
    background: #0d1117;
  }

  #preloader.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .preloader-logo {
    font-family: var(--serif);
    font-size: 3rem;
    font-weight: 400;
    color: var(--text);
    letter-spacing: normal;
    animation: fadeIn 0.5s ease forwards;
  }

  .preloader-bar-wrap {
    width: 140px;
    height: 2px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
    animation: fadeIn 0.5s ease 0.3s both;
  }

  .preloader-bar {
    height: 100%;
    width: 0;
    border-radius: 99px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    animation: fill 1.6s cubic-bezier(0.4, 0, 0.2, 1) 0.3s forwards;
  }

  .preloader-label {
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    font-weight: 500;
    text-transform: uppercase;
    color: var(--muted);
    animation: fadeIn 0.5s ease 0.5s both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fill {
    0% {
      width: 0%;
    }

    60% {
      width: 70%;
    }

    100% {
      width: 100%;
    }
  }
</style>
