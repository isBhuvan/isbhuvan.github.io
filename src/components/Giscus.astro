---
const REPO = "isbhuvan/isbhuvan.github.io";
const REPO_ID = "R_kgDOQxc2GQ";
const CATEGORY = "General";
const CATEGORY_ID = "DIC_kwDOQxc2Gc4C4fK8";
---

<section class="giscus-section">
  <div class="giscus-container">
    <div class="giscus-header">
      <span class="giscus-eyebrow">Discussion</span>
      <h2 class="giscus-title">Comments</h2>
    </div>

    <div class="giscus-wrap">
      <script
        is:inline
        src="https://giscus.app/client.js"
        data-repo={REPO}
        data-repo-id={REPO_ID}
        data-category={CATEGORY}
        data-category-id={CATEGORY_ID}
        data-mapping="pathname"
        data-strict="0"
        data-reactions-enabled="1"
        data-emit-metadata="0"
        data-input-position="top"
        data-theme="preferred_color_scheme"
        data-lang="en"
        data-loading="lazy"
        crossorigin="anonymous"
        async></script>
    </div>
  </div>
</section>

<script>
  function getGiscusTheme() {
    return document.documentElement.dataset.theme === "dark" ? "dark" : "light";
  }

  function sendThemeToGiscus(theme: string) {
    const iframe = document.querySelector<HTMLIFrameElement>(
      "iframe.giscus-frame",
    );
    if (!iframe?.contentWindow) return;
    iframe.contentWindow.postMessage(
      { giscus: { setConfig: { theme } } },
      "https://giscus.app",
    );
  }

  // Initial sync after Giscus iframe loads
  window.addEventListener("message", (event) => {
    if (event.origin !== "https://giscus.app") return;
    if (event.data?.giscus?.discussion !== undefined) return; // metadata events
    if (typeof event.data?.giscus === "object") {
      sendThemeToGiscus(getGiscusTheme());
    }
  });

  // Watch for theme toggle changes
  const observer = new MutationObserver(() => {
    sendThemeToGiscus(getGiscusTheme());
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ["data-theme"],
  });
</script>

<style>
  .giscus-section {
    border-top: 1px solid var(--border);
    padding: 3.5rem 0 4rem;
    background: var(--bg);
  }

  .giscus-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .giscus-header {
    margin-bottom: 2rem;
  }

  .giscus-eyebrow {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }

  .giscus-title {
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
    line-height: 1.15;
    margin: 0;
  }

  /* Override Giscus iframe border radius to match site radius */
  :global(.giscus-frame) {
    border-radius: var(--radius) !important;
  }
</style>
