---
interface Props {
  revealMode?: "portfolio" | "blog";
}

const { revealMode = "blog" } = Astro.props;
---

<script define:vars={{ revealMode }}>
  // ── Theme toggle ──────────────────────────────────────────────
  const SUN = `<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>`;
  const MOON = `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>`;
  const ICONS = { light: SUN, dark: MOON };
  const LABELS = { light: "Light", dark: "Dark" };

  let currentTheme =
    document.documentElement.getAttribute("data-theme") || "light";

  function setTheme(theme) {
    currentTheme = theme;
    document.documentElement.setAttribute("data-theme", theme);
    localStorage.setItem("theme", theme);
    document.getElementById("theme-icon")?.innerHTML !== undefined &&
      (document.getElementById("theme-icon").innerHTML = ICONS[theme]);
    document.getElementById("mobile-theme-icon")?.innerHTML !== undefined &&
      (document.getElementById("mobile-theme-icon").innerHTML = ICONS[theme]);
    const mLabel = document.getElementById("mobile-theme-label");
    if (mLabel) mLabel.textContent = LABELS[theme];
    document
      .getElementById("mobile-theme-btn")
      ?.classList.toggle("active", theme === "dark");
  }

  document
    .getElementById("theme-btn")
    ?.addEventListener("click", () =>
      setTheme(currentTheme === "light" ? "dark" : "light"),
    );
  document
    .getElementById("mobile-theme-btn")
    ?.addEventListener("click", () =>
      setTheme(currentTheme === "light" ? "dark" : "light"),
    );

  // ── Navbar scroll shadow ──────────────────────────────────────
  const navTop = document.getElementById("navbar-top");
  window.addEventListener(
    "scroll",
    () => {
      navTop?.classList.toggle("scrolled", window.scrollY > 10);
    },
    { passive: true },
  );

  // ── Preloader ─────────────────────────────────────────────────
  setTimeout(
    () => document.getElementById("preloader")?.classList.add("hidden"),
    2300,
  );

  // ── Scroll reveal ─────────────────────────────────────────────
  const reveals = document.querySelectorAll(".reveal");
  if ("IntersectionObserver" in window) {
    if (revealMode === "portfolio") {
      // Elements start visible in CSS; JS hides then reveals them.
      reveals.forEach((el) => el.classList.add("will-reveal"));
    }
    const threshold = revealMode === "portfolio" ? 0.08 : 0.07;
    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("visible");
            obs.unobserve(e.target);
          }
        });
      },
      { threshold },
    );
    reveals.forEach((el) => obs.observe(el));
  }
</script>
