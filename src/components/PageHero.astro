---
// src/components/PageHero.astro
interface Stat {
  num: string | number;
  label: string;
}

interface Props {
  eyebrow: string;
  title: string; // supports inline HTML e.g. "Things I've <span>built.</span>"
  sub: string;
  stats?: Stat[];
  maxWidth?: string;
}

const { eyebrow, title, sub, stats = [], maxWidth = "760px" } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero-grid-bg" aria-hidden="true"></div>
  <slot name="icon" />
  <div class="page-hero-inner" style={`max-width: ${maxWidth};`}>
    <div class="page-hero-eyebrow">{eyebrow}</div>
    <h1 class="page-hero-title" set:html={title} />
    <p class="page-hero-sub">{sub}</p>
    {
      stats.length > 0 && (
        <div class="page-hero-meta">
          {stats.map((s, i) => (
            <>
              {i > 0 && <div class="page-hero-divider" />}
              <div class="page-hero-stat">
                <span class="page-hero-stat-num">{s.num}</span>
                <span class="page-hero-stat-label">{s.label}</span>
              </div>
            </>
          ))}
        </div>
      )
    }
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding: 5rem 2rem 1rem;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .page-hero-grid-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.35;
  }

  .page-hero-inner {
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .page-hero-eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.1rem;
  }

  .page-hero-eyebrow::before {
    content: "";
    width: 22px;
    height: 1.5px;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .page-hero-title {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 400;
    color: var(--text);
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  /* accent span inside title */
  .page-hero-title :global(span) {
    color: var(--accent);
  }

  .page-hero-sub {
    font-size: 0.95rem;
    font-weight: 400;
    color: var(--muted);
    line-height: 1.75;
    max-width: 560px;
    margin-bottom: 0;
    letter-spacing: 0;
  }

  .page-hero-meta {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  .page-hero-stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .page-hero-stat-num {
    font-size: 1.9rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .page-hero-stat-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .page-hero-divider {
    width: 1px;
    height: 36px;
    background: var(--border);
    flex-shrink: 0;
  }

  /* ── Decorative icon (slotted) ── */
  :global(.page-header-icon) {
    position: absolute;
    right: 3rem;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0.065;
    color: var(--accent);
    width: clamp(160px, 22vw, 300px);
    height: auto;
    z-index: 0;
  }
  :root:not([data-theme="dark"]) :global(.page-header-icon) {
    opacity: 0.045;
  }

  @media (max-width: 768px) {
    .page-hero {
      padding: 4rem 1.5rem 3rem;
    }
    :global(.page-header-icon) {
      width: clamp(100px, 28vw, 180px);
      opacity: 0.04;
    }
  }

  @media (max-width: 580px) {
    .page-hero {
      padding: 3.5rem 1.25rem 2.5rem;
    }
    :global(.page-header-icon) {
      display: none;
    }
    .page-hero-meta {
      gap: 1.25rem;
    }
    .page-hero-stat-num {
      font-size: 1.5rem;
    }
  }
</style>
